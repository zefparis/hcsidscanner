{
  "name": "hcs-id-scanner",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@hcs/id-scanner-demo-web",
    "build": "npm run build --workspace=@hcs/id-scanner-demo-web",
    "build:demo": "npm run build --workspace=@hcs/id-scanner-demo-web",
    "type-check": "tsc -p packages/core/tsconfig.json && tsc -p packages/react/tsconfig.json && tsc -p packages/native/tsconfig.json && tsc -b apps/demo-web"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
