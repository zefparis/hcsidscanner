{
  "name": "hcs-id-scanner",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=@hcs/id-scanner-core",
    "type-check": "npm run build --workspace=@hcs/id-scanner-core && tsc -p packages/react/tsconfig.json && tsc -p packages/native/tsconfig.json && tsc -p apps/mobile/tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.2.48",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "@types/react": "18.2.48",
    "react": "$react",
    "react-native-safe-area-context": "4.8.2"
  }
}
