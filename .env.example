# ─── Signicat eID Hub (sandbox) ──────────────────────────────────────────
# Public — exposed in the bundle; OK to be in VITE_*.
VITE_SIGNICAT_CLIENT_ID=sandbox-spicy-picture-960
VITE_SIGNICAT_BASE_URL=https://sandbox.signicat.com
VITE_SIGNICAT_SCOPE=openid profile document
VITE_REDIRECT_URI=http://localhost:5173/callback

# Server-only — NEVER prefix with VITE_, never imported from src/*.
SIGNICAT_CLIENT_ID=sandbox-spicy-picture-960
SIGNICAT_CLIENT_SECRET=
SIGNICAT_BASE_URL=https://sandbox.signicat.com

# ─── AWS Rekognition (face match) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ─── HCS-U7 backend (KYC registration) ───────────────────────────────────
VITE_HCS_API_URL=https://hcs-u7-backend-kk0n.onrender.com
VITE_HCS_TENANT_ID=hcs-id-scanner-demo

# ─── Supabase Storage (portrait persistence) ─────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=kyc-documents
